<?xml version="1.0" encoding="UTF-8"?>
<!-- beans 태그는 주입할 클래스 집합 -->
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
	<!-- bean 태그는 개별 클래스를 정의 -->
	<!--bean 태그 속성 : id -> 클래스 별명 / class -> 개발자가 생성한 클래스 명(패키지 명 포함) -->
	<!--Name Service class : 일반 로직 처리
		NameController Class : NameService 반환값 처리(NameService에 의존적임)	
	 -->
	<bean id="nameService" class="com.di.spring_di_xml_constructor.NameService"/>
	<bean id="nameController" class="com.di.spring_di_xml_constructor.NameController">
		<!-- 생성자 기반으로 nameService가 참조(의존성 주입 생성자 통해) -->
		<constructor-arg ref="nameService"/>
	</bean>
</beans>
